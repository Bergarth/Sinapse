<UserControl
    x:Class="DesktopShell.Views.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:DesktopShell.ViewModels"
    mc:Ignorable="d">

    <Border Padding="16" BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Margin="12">
        <StackPanel Spacing="12">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Conversation Workspace" />

            <StackPanel Spacing="4">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Chat" />
                <TextBlock Text="Send a message to verify shell ↔ daemon chat flow." TextWrapping="Wrap" />

                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="10" MinHeight="140">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:ChatMessageViewModel">
                                <Border BorderBrush="Gainsboro" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                                    <StackPanel Spacing="2">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind SenderName, Mode=OneWay}" />
                                        <TextBlock
                                            Foreground="DarkOrange"
                                            FontSize="12"
                                            Text="{x:Bind WarningBannerText, Mode=OneWay}" />
                                        <TextBlock Text="{x:Bind Content, Mode=OneWay}" TextWrapping="Wrap" />
                                        <TextBlock Opacity="0.75" FontSize="12" Text="{x:Bind HandlerLabel, Mode=OneWay}" />
                                        <ItemsRepeater ItemsSource="{x:Bind Sources, Mode=OneWay}">
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="viewModels:SearchSourceViewModel">
                                                    <TextBlock FontSize="12" TextWrapping="Wrap">
                                                        <Run Text="Source: " />
                                                        <Run Text="{x:Bind Title, Mode=OneWay}" />
                                                        <Run Text=" — " />
                                                        <Run Text="{x:Bind Url, Mode=OneWay}" />
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                        <TextBlock Opacity="0.7" FontSize="12" Text="{x:Bind Timestamp, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </Border>

                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button
                        Content="Hold to Talk"
                        IsEnabled="{x:Bind ViewModel.CanUsePushToTalk, Mode=OneWay}"
                        Click="PushToTalk_Click"
                        PointerPressed="PushToTalk_PointerPressed"
                        PointerReleased="PushToTalk_PointerReleased"
                        PointerCanceled="PushToTalk_PointerReleased"
                        PointerCaptureLost="PushToTalk_PointerReleased" />
                    <ProgressRing Width="20" Height="20" IsActive="{x:Bind ViewModel.IsPushToTalkListening, Mode=OneWay}" />
                    <ProgressRing Width="20" Height="20" IsActive="{x:Bind ViewModel.IsPushToTalkTranscribing, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind ViewModel.PushToTalkStatusText, Mode=OneWay}" TextWrapping="Wrap" Width="420" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ProgressRing Width="20" Height="20" IsActive="{x:Bind ViewModel.IsSending, Mode=OneWay}" />
                    <TextBox
                        Width="520"
                        PlaceholderText="Type your message..."
                        Text="{x:Bind ViewModel.PendingMessageText, Mode=TwoWay}" />
                    <Button
                        Content="Send"
                        Click="SendMessage_Click"
                        IsEnabled="{x:Bind ViewModel.CanSendMessage, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{x:Bind ViewModel.WorkspaceAttachmentTitle, Mode=OneWay}" />
                <TextBlock Text="{x:Bind ViewModel.WorkspaceAttachmentHelpText, Mode=OneWay}" TextWrapping="Wrap" />
                <Button Content="{x:Bind ViewModel.AddFolderButtonLabel, Mode=OneWay}" HorizontalAlignment="Left" Click="AddFolder_Click" />
                <TextBlock Text="{x:Bind ViewModel.WorkspaceStatusText, Mode=OneWay}" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Workspace mode" />
                <TextBlock Text="{x:Bind ViewModel.WorkspaceModeLabel, Mode=OneWay}" />
                <TextBlock Text="{x:Bind ViewModel.WorkspaceModeDescription, Mode=OneWay}" TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton Content="Read-only" IsChecked="True" IsEnabled="False" />
                    <RadioButton Content="Read-write" IsEnabled="False" />
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{x:Bind ViewModel.WorkspaceRootDisplayTitle, Mode=OneWay}" />
                <TextBlock Text="{x:Bind ViewModel.WorkspaceRootDisplayDescription, Mode=OneWay}" TextWrapping="Wrap" />

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.AttachedWorkspaceRoots, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:WorkspaceRootViewModel">
                            <Border Padding="8" CornerRadius="6" BorderBrush="LightGray" BorderThickness="1" Margin="0,4,0,0">
                                <StackPanel Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName, Mode=OneWay}" />
                                    <TextBlock Text="{x:Bind RootPath, Mode=OneWay}" TextWrapping="Wrap" />
                                    <TextBlock Text="{x:Bind AccessModeLabel, Mode=OneWay, StringFormat='Mode: {0}'}" />
                                    <TextBlock Text="{x:Bind InventorySummary, Mode=OneWay}" />
                                    <TextBlock Text="{x:Bind SampleFileList, Mode=OneWay}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
