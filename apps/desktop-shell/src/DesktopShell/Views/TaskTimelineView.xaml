<UserControl
    x:Class="DesktopShell.Views.TaskTimelineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:DesktopShell.ViewModels"
    mc:Ignorable="d">

    <Border Padding="16" BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Margin="12">
        <StackPanel Spacing="10">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Task Timeline" />
            <TextBlock Text="Safe desktop actions now available (approval-gated): Open Notepad, Focus Chrome, Open this file, Type this into the selected field." TextWrapping="Wrap" />
            <Button
                Content="Open Notepad (approval-gated)"
                HorizontalAlignment="Left"
                IsEnabled="{x:Bind ViewModel.CanStartTask, Mode=OneWay}"
                Click="StartTask_Click" />
            <Button
                Content="Type hello into selected field"
                HorizontalAlignment="Left"
                IsEnabled="{x:Bind ViewModel.CanStartTask, Mode=OneWay}"
                Click="StartRiskyTask_Click" />

            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextWrapping="Wrap" />

            <Border
                BorderBrush="#CC8B0000"
                BorderThickness="2"
                CornerRadius="8"
                Padding="12"
                Background="#11FF0000"
                x:Load="{x:Bind ViewModel.HasPendingApproval, Mode=OneWay}">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="17" FontWeight="Bold" Text="Approval needed before this task can continue" />
                    <TextBlock
                        Text="Please review this action carefully. Nothing will run until you choose Approve, Deny, or Cancel task."
                        TextWrapping="Wrap" />
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.PendingApprovalActionSummary, Mode=OneWay}" TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.PendingApprovalReason, Mode=OneWay}" TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.PendingApprovalTarget, Mode=OneWay, StringFormat='Target: {0}'}" TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.PendingApprovalRiskClass, Mode=OneWay, StringFormat='Risk class: {0}'}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Approve and continue" Click="Approve_Click" IsEnabled="{x:Bind ViewModel.CanRespondToApproval, Mode=OneWay}" />
                        <Button Content="Deny action" Click="Deny_Click" IsEnabled="{x:Bind ViewModel.CanRespondToApproval, Mode=OneWay}" />
                        <Button Content="Cancel task" Click="CancelTask_Click" IsEnabled="{x:Bind ViewModel.CanRespondToApproval, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="8" MinHeight="120">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.TimelineEntries, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:TimelineEntryViewModel">
                            <Border BorderBrush="Gainsboro" BorderThickness="0,0,0,1" Padding="0,6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Emoji, Mode=OneWay}" />
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Title, Mode=OneWay}" />
                                        <TextBlock Text="{x:Bind Detail, Mode=OneWay}" TextWrapping="Wrap" />
                                        <TextBlock FontSize="12" Opacity="0.7" Text="{x:Bind Timestamp, Mode=OneWay}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
