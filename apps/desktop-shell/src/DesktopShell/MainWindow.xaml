<Window
    x:Class="DesktopShell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:DesktopShell.Views"
    mc:Ignorable="d"
    Title="DesktopShell">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="12,12,12,0" Padding="12" BorderBrush="Gray" BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="8">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Startup status" />
                <TextBlock Text="The shell requests daemon and environment status at startup." TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.ConnectionIndicatorEmoji, Mode=OneWay}" FontSize="18" />
                    <TextBlock Text="Daemon:" FontWeight="SemiBold" />
                    <TextBlock Text="{x:Bind ViewModel.DaemonStatus, Mode=OneWay}" />
                </StackPanel>

                <TextBlock Text="{x:Bind ViewModel.ConnectionDetail, Mode=OneWay}" TextWrapping="Wrap" />
                <TextBlock Text="{x:Bind ViewModel.DaemonVersion, Mode=OneWay, StringFormat='Daemon version: {0}'}" />
                <TextBlock Text="{x:Bind ViewModel.EnvironmentName, Mode=OneWay, StringFormat='Environment: {0}'}" />
                <TextBlock Text="{x:Bind ViewModel.EnvironmentStatus, Mode=OneWay, StringFormat='Environment status: {0}'}" TextWrapping="Wrap" />
                <TextBlock Text="{x:Bind ViewModel.LastSuccessfulConnection, Mode=OneWay, StringFormat='Last successful connection: {0}'}" />

                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Available capabilities" />
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.CapabilityStatuses, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <Button Content="Retry connection check" Click="RetryConnectionCheck_Click" HorizontalAlignment="Left" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <views:SidebarView Grid.Column="0" />

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <views:ChatView Grid.Row="0" />
                <views:TaskTimelineView Grid.Row="1" />
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <views:ArtifactPanelView Grid.Row="0" />
                <views:SettingsView Grid.Row="1" />
            </Grid>
        </Grid>
    </Grid>
</Window>
